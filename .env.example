# SecureDocs Configuration File Template
# Rename this file to '.env' and populate the values for production deployment

# Django Base Settings
SECRET_KEY=django-insecure-change-this-in-production-use-a-strong-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# OCI Autonomous Database (Oracle) Configuration
# Leave blank to fall back to Local SQLite database during development
OCI_DB_NAME=
OCI_DB_USER=
OCI_DB_PASSWORD=
OCI_WALLET_DIR=
OCI_WALLET_PASSWORD=

# Azure Blob Storage Configuration
# Leave blank to fall back to local disk storage during development
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONNECTION_STRING=
AZURE_CONTAINER_MEDIA=securedocs-media
AZURE_CONTAINER_STATIC=securedocs-static

# Cryptographic Keys (OWASP A02:2021)
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=3r0vPzI9G2hK5-aXmR8oD7fC9uV1wY4zL2xJ7hG4bQ0=

# Security Features (Toggles for OWASP compliance check)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSP_ENABLED=True
AXES_ENABLED=True
