# SecureDocs Configuration File Template
# Rename this file to '.env' and populate the values for production deployment

# Django Base Settings
SECRET_KEY=django-insecure-change-this-in-production-use-a-strong-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (OCI Autonomous Database / PostgreSQL / SQLite)
# For local SQLite development (default):
DATABASE_URL=sqlite:///db.sqlite3

# For OCI Autonomous DB (Oracle):
# DATABASE_URL=oracle://db_user:db_password@oracle_host:1521/service_name
# Or PostgreSQL on OCI/AWS:
# DATABASE_URL=postgres://db_user:db_password@db_host:5432/db_name

# Azure Blob Storage Configuration
# Leave blank to fall back to Local Storage during development
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER=securedocs-evidences

# Cryptographic Keys (OWASP A02:2021)
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=3r0vPzI9G2hK5-aXmR8oD7fC9uV1wY4zL2xJ7hG4bQ0=

# Security Features (Toggles for OWASP compliance check)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSP_ENABLED=True
AXES_ENABLED=True
